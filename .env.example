# POS Multimodal - Environment variables template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# IMPORTANT: If a real SUPABASE_SERVICE_ROLE_KEY was ever committed to git
# history, rotate it immediately in your Supabase project dashboard:
# Settings -> API -> Regenerate service_role secret.
# Treat the old key as fully compromised.

# Main process (Node / Electron)
# Used by src/shared/runtime-config.ts - never exposed to the renderer.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Renderer (Vite)
# Only the public/anon key belongs here. NEVER put the service role key here.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: external runtime config path
# Set this to load secrets from a file outside the repo (production deployments).
# POS_RUNTIME_CONFIG_PATH=/etc/pos/pos-runtime.env
